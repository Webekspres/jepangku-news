datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  CONTRIBUTOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum QuizStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum PollType {
  POLLING
  VOTING
}

enum PollStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum VideoStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContributorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  X
  YOUTUBE
  TIKTOK
}

enum CommentTargetType {
  ARTICLE
  POLL
  QUIZ
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum ReactionTargetType {
  ARTICLE
  POLL
  QUIZ
  COMMENT
}

enum ReactionType {
  LOVE
  LOL
  CUTE
  WIN
  WTF
  OMG
  GEEKY
  SCARY
  FAIL
  THUMB_UP
  THUMB_DOWN
}

enum NotificationType {
  ARTICLE_APPROVED
  ARTICLE_REJECTED
  ARTICLE_PENDING_REVIEW
  CONTRIBUTOR_APPLICATION_PENDING
  CONTRIBUTOR_APPROVED
  CONTRIBUTOR_REJECTED
  COMMENT_ON_ARTICLE
  COMMENT_REPLY
  WELCOME
  NEW_ARTICLE_IN_CATEGORY
}

enum NotificationPriority {
  NORMAL
  HIGH
}

model User {
  /// Clerk User ID — same as jepangku-core users.id (global identity anchor)
  id               String            @id
  email            String            @unique
  username         String            @unique
  name             String
  role             Role              @default(USER)
  avatarUrl        String?           @map("avatar_url")
  status           String            @default("active") // "active", "inactive", "banned"
  usernameChangedAt DateTime?        @map("username_changed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  lastLoginAt      DateTime?         @map("last_login_at")

  profile          UserProfile?
  articles         Article[]
  bookmarks        Bookmark[]
  quizAttempts     QuizAttempt[]
  pollVotes        PollVote[]
  files            File[]
  articleShares    ArticleShare[]
  articlesLastEdited Article[]       @relation("ArticleLastEditor")
  articleRevisions   ArticleRevision[]
  articleReviews     ArticleReview[]   @relation("ArticleReviewer")
  comments           Comment[]
  reactions          Reaction[]
  articleViews       ArticleView[]
  infoPagesUpdated   InfoPage[]      @relation("InfoPageEditor")
  pointTransactions  PointTransaction[]
  contributorApplications ContributorApplication[] @relation("ContributorApplications")
  contributorReviews    ContributorApplication[] @relation("ContributorApplicationReviews")
  auditLogs             AuditLog[]
  notifications         Notification[]
  emailOutbox           EmailOutbox[]
  newsletterSubscriptions NewsletterSubscription[]
  categorySubscriptions CategorySubscription[]

  @@map("users")
}

model PointTransaction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sourceApp    String   @default("news") @map("source_app")
  activityType String   @map("activity_type")
  sourceType   String   @map("source_type")
  sourceId     String?  @map("source_id")
  points       Int
  description  String?
  occurredAt   DateTime @default(now()) @map("occurred_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceApp, activityType, sourceType, sourceId], map: "point_transactions_user_activity_unique")
  @@index([userId, occurredAt(sort: Desc)])
  @@index([occurredAt])
  @@map("point_transactions")
}

model UserProfile {
  id                     String    @id @default(uuid())
  userId                 String    @unique @map("user_id")
  displayName            String    @map("display_name")
  bio                    String?
  welcomedAt             DateTime? @map("welcomed_at")
  lastDailyPointsModalAt DateTime? @map("last_daily_points_modal_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Notification {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  type      NotificationType
  title     String
  body      String?
  link      String?
  metadata  Json?
  dedupeKey String?              @map("dedupe_key")
  groupKey  String?              @map("group_key")
  priority  NotificationPriority @default(NORMAL)
  readAt    DateTime?            @map("read_at")
  expiresAt DateTime?            @map("expires_at")
  createdAt DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey], map: "notifications_user_dedupe_unique")
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([userId, groupKey, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("notifications")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?   @map("icon_url")
  color       String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  articles    Article[]
  subscriptions CategorySubscription[]

  @@map("categories")
}

model CategorySubscription {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
  @@map("category_subscriptions")
}

model Tag {
  id        String       @id @default(uuid())
  sourceApp String       @default("news") @map("source_app")
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now()) @map("created_at")

  articles  ArticleTag[]

  @@map("tags")
}

model Article {
  id               String          @id @default(uuid())
  sourceApp        String          @default("news") @map("source_app")
  authorId         String          @map("author_id")
  categoryId       String?         @map("category_id")
  title            String
  slug             String          @unique
  excerpt          String?
  content          String
  coverImageUrl    String?         @map("cover_image_url")
  status           ArticleStatus   @default(DRAFT)
  visibility       String          @default("public")
  isFeatured       Boolean         @default(false) @map("is_featured")
  isHot            Boolean         @default(false) @map("is_hot")
  publishedAt      DateTime?       @map("published_at")
  viewCount        Int             @default(0) @map("view_count")
  weeklyViewCount  Int             @default(0) @map("weekly_view_count")
  bookmarkCount    Int             @default(0) @map("bookmark_count")
  shareCount       Int             @default(0) @map("share_count")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  lastEditedById   String?         @map("last_edited_by_id")
  lastEditedAt     DateTime?       @map("last_edited_at")

  author           User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  lastEditedBy     User?           @relation("ArticleLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             ArticleTag[]
  reviews          ArticleReview[]
  revisions        ArticleRevision[]
  bookmarks        Bookmark[]
  shares           ArticleShare[]
  views            ArticleView[]

  @@map("articles")
}

model ArticleView {
  id         String   @id @default(uuid())
  articleId  String   @map("article_id")
  userId     String?  @map("user_id")
  visitorKey String   @map("visitor_key")
  viewedAt   DateTime @default(now()) @map("viewed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleId, viewedAt])
  @@index([articleId, visitorKey])
  @@map("article_views")
}

model ArticleTag {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@map("article_tags")
}

model ArticleReview {
  id             String        @id @default(uuid())
  articleId      String        @map("article_id")
  reviewerId     String        @map("reviewer_id")
  previousStatus ArticleStatus @map("previous_status")
  newStatus      ArticleStatus @map("new_status")
  note           String?
  reviewedAt     DateTime      @default(now()) @map("reviewed_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewer       User          @relation("ArticleReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@map("article_reviews")
}

model ArticleRevision {
  id             String        @id @default(uuid())
  articleId      String        @map("article_id")
  revisionNumber Int           @map("revision_number")
  editorId       String        @map("editor_id")
  changeNote     String?       @map("change_note")
  title          String
  excerpt        String?
  content        String
  coverImageUrl  String?       @map("cover_image_url")
  categoryId     String?       @map("category_id")
  status         ArticleStatus
  createdAt      DateTime      @default(now()) @map("created_at")

  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editor         User          @relation(fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([articleId, revisionNumber])
  @@index([articleId, createdAt])
  @@map("article_revisions")
}

model Bookmark {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  articleId         String    @map("article_id")
  firstBookmarkedAt DateTime  @default(now()) @map("first_bookmarked_at")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("bookmarks")
}

model ArticleShare {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  articleId         String    @map("article_id")
  shareMethod       String    @map("share_method") // "copy-link", "social", "email", etc
  pointsAwarded     Int       @default(5) @map("points_awarded")
  isPointAwarded    Boolean   @default(false) @map("is_point_awarded")
  sharedAt          DateTime  @default(now()) @map("shared_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("article_shares")
}

model Quiz {
  id                    String         @id @default(uuid())
  sourceApp             String         @default("news") @map("source_app")
  createdBy             String         @map("created_by")
  title                 String
  slug                  String         @unique
  description           String?
  thumbnailUrl          String?        @map("thumbnail_url")
  quizType              String         @default("trivia") @map("quiz_type")
  status                QuizStatus     @default(DRAFT)
  pointsReward          Int            @default(10) @map("points_reward")
  correctAnswerPoints   Int            @default(5) @map("correct_answer_points")
  allowRetry            Boolean        @default(false) @map("allow_retry")
  showResultImmediately Boolean        @default(true) @map("show_result_immediately")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  questions             QuizQuestion[]
  attempts              QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id           String             @id @default(uuid())
  quizId       String             @map("quiz_id")
  questionText String             @map("question_text")
  imageUrl     String?            @map("image_url")
  sortOrder    Int                @default(0) @map("sort_order")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  quiz         Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options      QuizOption[]
  answers      QuizAttemptAnswer[]

  @@map("quiz_questions")
}

model QuizOption {
  id           String              @id @default(uuid())
  questionId   String              @map("question_id")
  optionText   String              @map("option_text")
  imageUrl     String?             @map("image_url")
  isCorrect    Boolean             @default(false) @map("is_correct")
  sortOrder    Int                 @default(0) @map("sort_order")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  question     QuizQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers      QuizAttemptAnswer[]

  @@map("quiz_options")
}

model QuizAttempt {
  id             String              @id @default(uuid())
  quizId         String              @map("quiz_id")
  userId         String              @map("user_id")
  score          Float
  totalQuestions Int                 @map("total_questions")
  correctAnswers Int                 @map("correct_answers")
  pointsAwarded  Int                 @map("points_awarded")
  isPointAwarded Boolean             @default(true) @map("is_point_awarded")
  startedAt      DateTime            @default(now()) @map("started_at")
  submittedAt    DateTime            @default(now()) @map("submitted_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  quiz           Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers        QuizAttemptAnswer[]

  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id               String       @id @default(uuid())
  attemptId        String       @map("attempt_id")
  questionId       String       @map("question_id")
  selectedOptionId String       @map("selected_option_id")
  isCorrect        Boolean      @map("is_correct")
  createdAt        DateTime     @default(now()) @map("created_at")

  attempt          QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   QuizOption   @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  @@map("quiz_attempt_answers")
}

model Poll {
  id                    String         @id @default(uuid())
  sourceApp             String         @default("news") @map("source_app")
  createdBy             String         @map("created_by")
  title                 String
  slug                  String         @unique
  description           String?
  pollType              PollType       @default(POLLING) @map("poll_type")
  status                PollStatus     @default(DRAFT)
  thumbnailUrl          String?        @map("thumbnail_url")
  pointsReward          Int            @default(5) @map("points_reward")
  allowGuestVote        Boolean        @default(false) @map("allow_guest_vote")
  showResultBeforeVote  Boolean        @default(false) @map("show_result_before_vote")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  questions             PollQuestion[]
  votes                 PollVote[]

  @@map("polls")
}

model PollQuestion {
  id           String       @id @default(uuid())
  pollId       String       @map("poll_id")
  questionText String       @map("question_text")
  imageUrl     String?      @map("image_url")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  poll         Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  options      PollOption[]
  votes        PollVote[]

  @@map("poll_questions")
}

model PollOption {
  id           String       @id @default(uuid())
  questionId   String       @map("question_id")
  optionText   String       @map("option_text")
  imageUrl     String?      @map("image_url")
  voteCount    Int          @default(0) @map("vote_count")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  question     PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  votes        PollVote[]

  @@map("poll_options")
}

model PollVote {
  id             String       @id @default(uuid())
  pollId         String       @map("poll_id")
  questionId     String       @map("question_id")
  optionId       String       @map("option_id")
  userId         String       @map("user_id")
  pointsAwarded  Int          @map("points_awarded")
  isPointAwarded Boolean      @default(true) @map("is_point_awarded")
  votedAt        DateTime     @default(now()) @map("voted_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  poll           Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  question       PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option         PollOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, questionId, userId])
  @@map("poll_votes")
}

model File {
  id               String   @id @default(uuid())
  storagePath      String   @map("storage_path")
  originalFilename String   @map("original_filename")
  contentType      String   @map("content_type")
  size             Int
  userId           String   @map("user_id")
  isDeleted        Boolean  @default(false) @map("is_deleted")
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("files")
}

model Comment {
  id         String            @id @default(uuid())
  sourceApp  String            @default("news") @map("source_app")
  targetType CommentTargetType @map("target_type")
  targetId   String            @map("target_id")
  userId     String            @map("user_id")
  parentId   String?           @map("parent_id")
  content    String
  status     CommentStatus     @default(VISIBLE)
  editedAt   DateTime?         @map("edited_at")
  deletedAt  DateTime?         @map("deleted_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]         @relation("CommentReplies")

  @@index([targetType, targetId, status, createdAt])
  @@index([parentId])
  @@map("comments")
}

model InfoPage {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  subtitle        String?
  content         String
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  isPublished     Boolean  @default(true) @map("is_published")
  sortOrder       Int      @default(0) @map("sort_order")
  updatedById     String?  @map("updated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  updatedBy       User?    @relation("InfoPageEditor", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("info_pages")
}

model Reaction {
  id         String             @id @default(uuid())
  sourceApp  String             @default("news") @map("source_app")
  targetType ReactionTargetType @map("target_type")
  targetId   String             @map("target_id")
  userId     String             @map("user_id")
  type       ReactionType
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId])
  @@index([targetType, targetId])
  @@map("reactions")
}

model Video {
  id           String      @id @default(uuid())
  title        String
  slug         String      @unique
  description  String?
  youtubeId    String      @map("youtube_id")
  thumbnailUrl String?     @map("thumbnail_url")
  status       VideoStatus @default(DRAFT)
  isFeatured   Boolean     @default(false) @map("is_featured")
  viewCount    Int         @default(0) @map("view_count")
  publishedAt  DateTime?   @map("published_at")
  createdBy    String?     @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([isFeatured, status])
  @@map("videos")
}

model AdSlot {
  id        String    @id @default(uuid())
  position  String
  title     String?
  imageUrl  String    @map("image_url")
  linkUrl   String?   @map("link_url")
  altText   String?   @map("alt_text")
  isActive  Boolean   @default(true) @map("is_active")
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")
  sortOrder Int       @default(0) @map("sort_order")
  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([position, isActive])
  @@map("ad_slots")
}

model SiteSocialLink {
  platform  SocialPlatform @id
  url       String
  isEnabled Boolean        @default(true) @map("is_enabled")
  sortOrder Int            @default(0) @map("sort_order")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("site_social_links")
}

model ContributorApplication {
  id           String                       @id @default(uuid())
  userId       String                       @map("user_id")
  motivation   String
  portfolioUrl String?                      @map("portfolio_url")
  status       ContributorApplicationStatus @default(PENDING)
  adminNote    String?                      @map("admin_note")
  reviewedById String?                      @map("reviewed_by_id")
  reviewedAt   DateTime?                    @map("reviewed_at")
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")

  user       User  @relation("ContributorApplications", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ContributorApplicationReviews", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("contributor_applications")
}

model AuditLog {
  id          String   @id @default(uuid())
  sourceApp   String   @default("news") @map("source_app")
  category    String
  action      String
  actorId     String?  @map("actor_id")
  actorRole   Role?    @map("actor_role")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  targetLabel String?  @map("target_label")
  targetHref  String?  @map("target_href")
  summary     String
  note        String?
  metadata    Json?
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([category, occurredAt(sort: Desc)])
  @@index([actorId, occurredAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

model EmailOutbox {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  template    String
  toEmail     String            @map("to_email")
  subject     String
  payload     Json
  dedupeKey   String?           @map("dedupe_key")
  status      EmailOutboxStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?           @map("last_error")
  scheduledAt DateTime          @default(now()) @map("scheduled_at")
  sentAt      DateTime?         @map("sent_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey], map: "email_outbox_user_dedupe_unique")
  @@index([status, scheduledAt])
  @@map("email_outbox")
}

model NewsletterSubscription {
  id               String    @id @default(uuid())
  email            String    @unique
  userId           String?   @map("user_id")
  isActive         Boolean   @default(true) @map("is_active")
  unsubscribeToken String    @unique @map("unsubscribe_token")
  subscribedAt     DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt   DateTime? @map("unsubscribed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isActive, subscribedAt(sort: Desc)])
  @@map("newsletter_subscriptions")
}
