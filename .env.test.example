# ============================================
# TEST ENVIRONMENT — jepangku-news (template)
# ============================================
# Copy to .env.test (gitignored):
#   cp .env.test.example .env.test
#
# Used by: bun run test:unit · test:integration · test:smoke · test:db:prepare
# CI: secrets injected via .github/workflows/deploy.yml (does not commit .env.test)

NODE_ENV=test

# ============================================
# DATABASE (required for db:seed & integration)
# ============================================
DB_USER=root
DB_PASSWORD=root
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/jepangku_news_test?client_encoding=UTF8
PGCLIENTENCODING=UTF8

# ============================================
# APP URLS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEWS_BASE_URL=http://localhost:3000

# ============================================
# CLERK (optional for unit; required for integration auth)
# ============================================
AUTH_PROVIDER=clerk
NEXT_PUBLIC_AUTH_PROVIDER=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Maps to seeded ADMIN portal user (see tests/fixtures/clerk-accounts.ts)
ADMIN_EMAIL=admin+clerk_test@jepangku.com
CONTRIBUTOR_TEST_EMAIL=kontributor+clerk_test@jepangku.com

# ============================================
# REDIS (optional — rate limit falls back to in-memory)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# CORE (optional for unit/smoke)
# ============================================
# CORE_API_URL=http://localhost:8080
# CORE_SERVICE_TOKEN=
