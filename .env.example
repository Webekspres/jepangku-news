[TEMPLATE]
# ============================================
# DATABASE CONFIGURATION
# ============================================
# Dev lokal (PostgreSQL di laptop):
# Lalu set TARGET_DB=jepangku_news(default) atau nama DB Anda.
DB_USER=Your_Database_User
DB_PASSWORD=Your_Database_Password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/jepangku_news

# ============================================
# AUTHENTICATION
# ============================================
# Auth: Clerk only (login/register via /sign-in, /sign-up)
AUTH_PROVIDER=clerk
NEXT_PUBLIC_AUTH_PROVIDER=clerk

# Clerk (required)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# Admin placeholder — login via Clerk with this email to receive ADMIN role (see prisma/seed.js)
# ADMIN_EMAIL="admin+clerk_test@jepangku.com"
# CONTRIBUTOR_TEST_EMAIL="kontributor+clerk_test@jepangku.com"
# USER test account (seeded as sample user): budi+clerk_test@jepangku.com — OTP dev 424242

# Legacy (unused with Clerk-only auth)
# JWT_SECRET="your-super-secret-jwt-key-here"
# JWT_EXPIRATION=86400

# ============================================
# JEPANGKU CORE SERVICE (Fase B+)
# ============================================
# Server-to-server & token exchange — lihat jepangku-core/docs/PHASE0-PHASE1.md
# Dev lokal: http://localhost:8080 | Prod: https://core.jepangku.com (jangan http — POST gagal pada redirect 301)
# CORE_API_URL="http://localhost:8080"
# CORE_SERVICE_TOKEN="<sama dengan CORE_SERVICE_TOKEN di jepangku-core>"
# JWT verify (Fase 1) — sync dari Core: cd jepangku-core && bun run jwt:sync-public-key-to-clients
# CORE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
# CORE_JWT_ISSUER=https://core.jepangku.com
# CORE_JWT_AUDIENCE=jepangku

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
# Cloudflare Account ID
# Found in Cloudflare Dashboard > Workers & Pages > Settings
R2_ACCOUNT_ID=Your_Cloudflare_Account_ID

# R2 API Token - Access Key ID
# Create in Cloudflare Dashboard > R2 > Settings > API Tokens
R2_ACCESS_KEY_ID=Your_R2_Access_Key_ID

# R2 API Token - Access Key Secret
R2_ACCESS_KEY_SECRET=Your_R2_Access_Key_Secret

# R2 Bucket Name
R2_BUCKET_NAME=jepangku-storage

# R2 Public URL (for serving files)
# Format: https://<bucket-id>.r2.cloudflarestorage.com
# Or custom domain if configured
R2_PUBLIC_URL=https://your-bucket-id.r2.cloudflarestorage.com

# ============================================
# JEPANGKU LMS (kursus.jepangku.com)
# ============================================
# Override opsional. Tanpa env: staging/preview/dev → dev.kursus.jepangku.com,
# production → kursus.jepangku.com
NEXT_PUBLIC_LMS_URL="https://dev.kursus.jepangku.com"

# Partner API key (server-only) — wajib agar kursus muncul di homepage teaser.
# Harus SAMA dengan LMS_PARTNER_API_KEY yang diset di server LMS (dev.kursus.jepangku.com).
# Tanpa ini, /api/v1/public/courses balas 401/503 → teaser fallback "Segera Hadir".
LMS_PARTNER_API_KEY=""

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Application URL (for frontend)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Base URL (for API requests)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Node environment (development, production)
NODE_ENV=development

# Log level — Pino: trace | debug | info | warn | error | fatal
# Production: LOG_LEVEL=warn (hanya warn & error, hemat kuota)
LOG_LEVEL=info

# ============================================
# SECURITY & MONITORING (optional)
# ============================================
# Rate limiting — pilih salah satu backend (kosongkan keduanya = in-memory fallback)
# Dev lokal: Redis standar
# REDIS_URL="redis://localhost:6379"
# Prod Vercel/serverless: Upstash REST (disarankan)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Webhook untuk error tracking (Discord/Slack-compatible JSON POST)
# MONITORING_WEBHOOK_URL="https://hooks.example.com/..."

# Log drain — forward warn/error JSON (Vercel Log Drain / Axiom / custom HTTP)
# LOG_DRAIN_URL="https://your-log-drain-endpoint"
# LOG_SERVICE_NAME="jepangku-news"

# Image moderation API (opsional — tanpa ini hanya validasi format file)
# IMAGE_MODERATION_ENDPOINT="https://api.example.com/moderate"
# IMAGE_MODERATION_API_KEY="your-api-key"

# ============================================  
# OPTIONAL: THIRD-PARTY SERVICES
# ============================================
# Google Analytics
# NEXT_PUBLIC_ANALYTICS_ID="G-XXXXXXXXXX"

# Email — Resend (transactional + newsletter)
# 1. Verify domain at https://resend.com/domains
# 2. Sender distinct from Clerk auth (e.g. portal@send.jepangku.com)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="notifications@jepangku.com"
# EMAIL_FROM_NAME="JepangKu"
# EMAIL_REPLY_TO="support@jepangku.com"
#
# Async email queue — QStash publishes to POST /api/internal/email/process
# Scheduled article publish — QStash publishes to POST /api/internal/articles/publish (same token + signing keys)
# Create at https://console.upstash.com/qstash (copy token + signing keys for your region)
# QSTASH_URL="https://qstash-eu-central-1.upstash.io"
# QSTASH_TOKEN="..."
# QSTASH_CURRENT_SIGNING_KEY="sig_..."
# QSTASH_NEXT_SIGNING_KEY="sig_..."
# Shared secret forwarded to the process route (Bearer) — generate: openssl rand -hex 32
# EMAIL_QUEUE_SECRET="your-random-long-secret"
# Set true only when using a public tunnel (ngrok) so QStash can reach local dev server
# QSTASH_PUBLISH_IN_DEV="false"

# ============================================
# NOTES
# ============================================
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Other variables are server-side only
# - Link sosial media: Admin → Konten → Sosial Media (bukan env)
# - Never commit sensitive values to version control
