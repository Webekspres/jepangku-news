# ==================== DATABASE ====================
# MongoDB connection URL
# Example: mongodb://localhost:27017 (local)
# Example: mongodb+srv://user:password@cluster.mongodb.net (MongoDB Atlas)
MONGO_URL=

# Database name
DB_NAME=

# ==================== AUTHENTICATION ====================
# Secret key untuk JWT token generation
# Generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# ==================== ADMIN CREDENTIALS ====================
# Default admin email untuk setup awal
ADMIN_EMAIL=

# Default admin password untuk setup awal
# PENTING: Ubah password ini setelah first login!
ADMIN_PASSWORD=

# ==================== FRONTEND ====================
# URL frontend (untuk CORS configuration)
FRONTEND_URL=