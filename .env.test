# ============================================
# TEST ENVIRONMENT — jepangku-news
# ============================================
# Used by: bun run test:unit · test:integration · test:smoke · test:db:prepare
# Copy real Clerk keys from .env.local when running authenticated E2E locally.
# CI: inject secrets via pipeline env vars (same names).

NODE_ENV=test

# ============================================
# DATABASE (required for db:seed & integration)
# ============================================
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/jepangku_news_test

# ============================================
# APP URLS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEWS_BASE_URL=http://localhost:3000

# ============================================
# CLERK (optional for unit tests; required for seed + auth E2E)
# ============================================
AUTH_PROVIDER=clerk
NEXT_PUBLIC_AUTH_PROVIDER=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Maps to seeded ADMIN portal user (see tests/fixtures/clerk-accounts.ts)
ADMIN_EMAIL=admin+clerk_test@jepangku.com
CONTRIBUTOR_TEST_EMAIL=kontributor+clerk_test@jepangku.com

# ============================================
# REDIS (optional — rate limit falls back to in-memory)
# ============================================
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# CORE (optional for unit/smoke; needed for full integration)
# ============================================
# CORE_API_URL=http://localhost:8080
# CORE_SERVICE_TOKEN=
# CORE_JWT_PUBLIC_KEY=
# CORE_JWT_ISSUER=https://core.jepangku.com
# CORE_JWT_AUDIENCE=jepangku
